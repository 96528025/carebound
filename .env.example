# ===== Scalekit AgentKit (必填，去掉假数据靠这 3 个) =====
SCALEKIT_ENV_URL=
SCALEKIT_CLIENT_ID=
SCALEKIT_CLIENT_SECRET=

# Connection 名字（要和你在 Scalekit 后台建的 Connection 名字一模一样）
GMAIL_CONNECTION_NAME=gmail
GOOGLE_CALENDAR_CONNECTION_NAME=googlecalendar

# 关掉 demo 标签，显示走的是真 Scalekit 身份
DEMO_IDENTITY_MODE=false

# ===== Claude 智能提取（选填；没有就用死板正则兜底） =====
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ===== Actian VectorAI（选填；先用内存兜底即可） =====
STORAGE_MODE=fallback
